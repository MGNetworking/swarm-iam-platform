# Environnement : linux-server (VPS bare metal / Hetzner / OVH)
# Copier ce fichier en .env et adapter les valeurs à votre serveur.
#
#   cp environments/linux-server/.env.example environments/linux-server/.env

# Kubernetes
NAMESPACE=iam-system

# Keycloak — adapter au DNS de votre serveur
KEYCLOAK_HOSTNAME=keycloak.mondomaine.com

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb

# Infisical — credentials du service account (Universal Auth)
# Créer un service account sur https://app.infisical.com
# Projet : swarm-iam-platform / Environnement : prod
INFISICAL_CLIENT_ID=<CLIENT_ID_INFISICAL>
INFISICAL_CLIENT_SECRET=<CLIENT_SECRET_INFISICAL>

# Les secrets applicatifs (PG_PASSWORD, REDIS_PASSWORD, KEYCLOAK_ADMIN_PASSWORD)
# ne sont PLUS dans ce fichier — ils sont gérés dans Infisical et synchronisés
# automatiquement vers Kubernetes par ESO (External Secrets Operator).
