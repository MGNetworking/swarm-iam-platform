# Environnement : linux-server (VPS bare metal / Hetzner / OVH)
# Adapter ces valeurs à votre serveur avant déploiement.

# Kubernetes
NAMESPACE=iam-system

# Keycloak — adapter au DNS de votre serveur
KEYCLOAK_HOSTNAME=keycloak.example.com

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb
