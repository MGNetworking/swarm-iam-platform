# Environnement : local-dev (WSL2 — tests locaux)
# Adapter KEYCLOAK_HOSTNAME à l'IP de votre WSL2 si besoin.

# Kubernetes
NAMESPACE=iam-system

# Keycloak — hostname local (à déclarer dans /etc/hosts WSL2 + hosts Windows)
KEYCLOAK_HOSTNAME=http://keycloak.local

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb
