# Environnement : local-dev (WSL2 — tests locaux avec k3d)
# Copier ce fichier en .env et adapter si besoin.
#
#   cp environments/local-dev/.env.example environments/local-dev/.env

# Kubernetes
NAMESPACE=iam-system

# Keycloak — hostname local
# Ajouter dans /etc/hosts WSL2 et C:\Windows\System32\drivers\etc\hosts (Windows) :
#   127.0.0.1  keycloak.local
KEYCLOAK_HOSTNAME=keycloak.local

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb

# Infisical — credentials du service account (Universal Auth)
# Utiliser un environnement "dev" dans le projet Infisical pour les tests locaux.
INFISICAL_CLIENT_ID=<CLIENT_ID_INFISICAL>
INFISICAL_CLIENT_SECRET=<CLIENT_SECRET_INFISICAL>
