# Environnement : cloud/azure (AKS — Azure Kubernetes Service)
# Adapter ces valeurs à votre cluster AKS avant déploiement.

# Kubernetes
NAMESPACE=iam-system

# Keycloak — adapter au DNS Azure (ex: keycloak.region.cloudapp.azure.com)
KEYCLOAK_HOSTNAME=keycloak.example.azure.com

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb
