# Environnement : cloud/azure (Azure Kubernetes Service — AKS)
# Copier ce fichier en .env et adapter les valeurs.
#
#   cp environments/cloud/azure/.env.example environments/cloud/azure/.env

# Kubernetes
NAMESPACE=iam-system

# Keycloak — adapter au DNS de votre cluster AKS
KEYCLOAK_HOSTNAME=keycloak.mondomaine.com

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb

# Infisical — credentials du service account (Universal Auth)
# Utiliser un environnement "prod-azure" dans le projet Infisical.
INFISICAL_CLIENT_ID=<CLIENT_ID_INFISICAL>
INFISICAL_CLIENT_SECRET=<CLIENT_SECRET_INFISICAL>
