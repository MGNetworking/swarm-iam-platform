# Environnement : cloud/aws (EKS — Elastic Kubernetes Service)
# Adapter ces valeurs à votre cluster EKS avant déploiement.

# Kubernetes
NAMESPACE=iam-system

# Keycloak — adapter au DNS AWS (ex: keycloak.elb.region.amazonaws.com)
KEYCLOAK_HOSTNAME=keycloak.example.aws.com

# PostgreSQL
PG_DNS=postgresql
DB_NAME=kc_db
USER_BD=admin
PORT_BD=5432

# Redis
REDIS_MAX_MEMORY=512mb
